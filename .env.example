# Supabase — required for auth + data
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Sentry — optional. Leave empty to disable error tracking.
# Create a project at https://sentry.io and paste the DSN below.
VITE_SENTRY_DSN=

# PostHog — optional. Leave empty to disable analytics.
# Project API Key (starts with phc_) from PostHog → Project Settings → Project API Key.
# Safe to commit / ship in client code: it's the public write-only key.
# Host defaults to https://us.i.posthog.com if not set.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
